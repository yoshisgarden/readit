# keystore.properties をこのファイルからコピーして作成し、自分の値に書き換えてください。
# keystore.properties 自体は .gitignore で除外されます（コミット禁止）。
#
# storeFile     : keystore (.jks) ファイルへの絶対パス。バックスラッシュは \\ でエスケープ。
# storePassword : keystore 自体のパスワード
# keyAlias      : 鍵のエイリアス名
# keyPassword   : 鍵のパスワード（多くの場合 storePassword と同じ）

storeFile=C:\\Users\\ad12d\\keystores\\readit-release.jks
storePassword=CHANGE_ME
keyAlias=readit
keyPassword=CHANGE_ME
